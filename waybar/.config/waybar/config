{
    "layer": "top",
    "position": "top",
    "modules-left": [
        "niri/mode",
        "niri/workspaces",
        "custom/arrow-workspace",
        "niri/window"
    ],
    "modules-right": [
        "custom/arrow-end",
        "pulseaudio",
        "custom/arrow#pulseaudio-network",
        "network",
        "custom/arrow#network-memory",
        "memory",
        "custom/arrow#memory-language",
        "niri/language",
        "custom/arrow#language-tray",
        "tray",
        "custom/arrow#tray-date",
        "clock#date",
        "custom/arrow#date-time",
        "clock#time"
    ],
    "custom/arrow-workspace": {
        "format": "\ue0b0",
        "tooltip": false
    },
    "custom/arrow-end": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#pulseaudio-network": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#network-memory": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#memory-language": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#language-tray": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#tray-date": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#date-time": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}\uf294 {volume}%",
        "format-muted": "\uf026",
        "format-icons": {
            "headphone": "\uf025",
            "hands-free": "\uf590",
            "headset": "\uf590",
            "phone": "\uf095",
            "portable": "\uf095",
            "car": "\uf1b9",
            "default": [
                "\uf027",
                "\uf028"
            ]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip": false
    },
    "network": {
        "interval": 5,
        "format-wifi": "\uf1eb {essid} ({signalStrength}%)",
        "format-ethernet": "\udb81\udc8b  {ifname}",
        "format-disconnected": "No connection",
        "format-alt": "\ueb50  {ipaddr}/{cidr}",
        "tooltip": false
    },
    "memory": {
        "interval": 5,
        "format": "\uefc5  {used:0.1f}G/{total:0.1f}G",
        "states": {
            "warning": 70,
            "critical": 90
        },
        "tooltip": false
    },
    "niri/language": {
        "format": "\udb80\udf0c  {}",
        "min-length": 5,
        "on-click": "niri msg action switch-layout next",
        "tooltip": false
    },
    "tray": {
        "format": "\udb80\udf0c  {}",
        "min-length": 5,
        "on-click": "niri msg action switch-layout next",
        "tooltip": false
    },
    "clock#date": {
        "interval": 20,
        "format": "{:%e %b %Y}",
        "tooltip": true,
        "tooltip-format": "{:%e %B %Y}"
    },
    "clock#time": {
        "interval": 10,
        "format": "{:%H:%M}",
        "tooltip": false,
        "on-click": "for i in {1..5}; do dunstctl history-pop; done",
        "on-click-right": "dunstctl close-all"
    }
}