{
    "layer": "top",
    "position": "top",
    "modules-left": [
        "niri/mode",
        "niri/workspaces",
        "custom/arrow-workspace",
        "niri/window"
    ],
    "modules-right": [
        "custom/arrow-end",
        "pulseaudio",
        "custom/arrow#pulseaudio-mpris",
        "mpris",
        "custom/arrow#mpris-updates",
        "custom/updates",
        "custom/arrow#updates-memory",
        "memory",
        "custom/arrow#memory-language",
        "niri/language",
        "custom/arrow#language-tray",
        "tray",
        "clock#date",
        "custom/arrow#date-time",
        "clock#time"
    ],
    "custom/arrow-workspace": {
        "format": "\ue0b0",
        "tooltip": false
    },
    "custom/arrow-end": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#pulseaudio-mpris": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#mpris-updates": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#updates-memory": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#memory-language": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#language-tray": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#tray-date": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "custom/arrow#date-time": {
        "format": "\ue0b2",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}\uf294 {volume}%",
        "format-muted": "\uf026",
        "format-icons": {
            "headphone": "\uf025",
            "hands-free": "\uf590",
            "headset": "\uf590",
            "phone": "\uf095",
            "portable": "\uf095",
            "car": "\uf1b9",
            "default": [
                "\uf027",
                "\uf028"
            ]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip": false
    },
    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "{status_icon} <i>{title}</i>",
        "player-icons": {
            "default": "\u25b6",
            "spotify": "\uf1bc",
            "firefox": "\uf269"
        },
        "status-icons": {
            "paused": "\u23f8"
        },
        "max-length": 40,
        "interval": 1
    },
    "custom/updates": {
        "format": " {icon} {0} ",
        "return-type": "json",
        "format-icons": {
            "pending-updates": "\uf019 ",
            "updated": "\uf05d"
        },
        "exec-if": "which waybar-updates",
        "exec": "waybar-updates"
    },
    "memory": {
        "interval": 5,
        "format": "\uefc5  {used:0.1f}G/{total:0.1f}G",
        "states": {
            "warning": 70,
            "critical": 90
        },
        "tooltip": false
    },
    "niri/language": {
        "format": "\udb80\udf0c  {}",
        "min-length": 5,
        "on-click": "niri msg action switch-layout next",
        "tooltip": false
    },
    "tray": {
        "format": "\udb80\udf0c  {}",
        "min-length": 5,
        "on-click": "niri msg action switch-layout next",
        "tooltip": false
    },
    "clock#date": {
        "interval": 20,
        "format": "{:%e %b %Y}",
        "tooltip": true,
        "tooltip-format": "<span color='#89b4fa' size='large' weight='bold'>{:%Y %B}</span>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months": "<span><b>{}</b></span>",
                "days": "<span><b>{}</b></span>",
                "weeks": "<span><b>W{}</b></span>",
                "weekdays": "<span><b>{}</b></span>",
                "today": "<span><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "clock#time": {
        "interval": 10,
        "format": "{:%H:%M}",
        "tooltip": false,
        "on-click": "for i in {1..5}; do dunstctl history-pop; done",
        "on-click-right": "dunstctl close-all"
    }
}
