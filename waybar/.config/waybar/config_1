{
    "layer": "top",
    "position": "top",

    "modules-left": [
        "niri/mode",
        "niri/workspaces",
        "custom/arrow-workspace",
        "niri/window"
    ],

    "modules-right": [
	"custom/arrow#network-memory",
        "custom/arrow9",
        "pulseaudio",

        "custom/arrow8",
        "network",  

        "custom/arrow7",
        "memory",
        
        // "custom/arrow6",
