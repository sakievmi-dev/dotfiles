    // Modules
    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format-time": "{H}:{M:02}",
        "format": "{icon} {capacity}% ({time})",
        "format-charging": "пѓ§ {capacity}% ({time})",
        "format-charging-full": "пѓ§ {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-alt": "{icon} {power}W",
        "format-icons": [
            "п‰„",
            "п‰ѓ",
            "п‰‚",
            "п‰Ѓ",
            "п‰Ђ"
        ],
        "tooltip": false
    },

    "cpu": {
        "interval": 5,
        "tooltip": false,
        "format": "п‹› {usage}%",
        "format-alt": "п‹› {load}",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "temperature": {
        "critical-threshold": 90,
        "interval": 5,
        "format": "{icon} {temperatureC}В°",
        "format-icons": [
            "п‹‹",
            "п‹Љ",
            "п‹‰",
            "п‹€",
            "п‹‡"
        ],
        "tooltip": false
    },

    "clock#time": {
        "interval": 10,
        "format": "{:%H:%M}",
		"tooltip": false,
    	// Click actions
		"on-click": "for i in {1..5}; do dunstctl history-pop; done",
    	"on-click-right": "dunstctl close-all"
    },

    "clock#date": {
        "interval": 20,
        "format": "{:%e %b %Y}",
        "tooltip": true,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        //"tooltip-format": "{:%e %B %Y}"
    },   

    "memory": {
        "interval": 5,
        "format": "\uefc5  {used:0.1f}G/{total:0.1f}G",
        "states": {
            "warning": 70,
            "critical": 90
        },
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "format-wifi": "п‡« {essid} ({signalStrength}%)",
        "format-ethernet": "\udb81\udc8b  {ifname}",
        "format-disconnected": "No connection",
        "format-alt": "\ueb50  {ipaddr}/{cidr}",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}пЉ” {volume}%",
        "format-muted": "пЂ¦",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ§", "пЂЁ"]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip": false
    },   

    "niri/language": {
            "format": "\udb80\udf0c  {}",
            "min-length": 5,
            "on-click": "niri msg action switch-layout next",
            "tooltip": false
    },   

    "tray": {
        "icon-size": 16,
        "spacing": 5
    },

