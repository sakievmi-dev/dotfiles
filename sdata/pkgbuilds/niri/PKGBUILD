pkgname=saki-dots-niri
pkgver=1.0
pkgrel=2
pkgdesc='Niri package for sakievmi-dots'
arch=(any)
license=(None)

depends=(
    niri
    xwayland-satellite
    xdg-desktop-portal-gnome
    xdg-desktop-portal-gtk
    noto-fonts noto-fonts-cjk
    swww
    ttf-twemoji-color
    bibata-cursor-theme
    )

source=('yamis::git+https://bitbucket.org/dirn-typo/yet-another-monochrome-icon-set.git')
sha256sums=('SKIP')

package() {
    install -d "$pkgdir/usr/share/icons/yamis"
    cp -r "$srcdir/yamis/"* "$pkgdir/usr/share/icons/yamis/"
    
    rm -rf "$pkgdir/usr/share/icons/yamis/.git"
}
